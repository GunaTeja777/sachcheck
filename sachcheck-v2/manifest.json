{
  "manifest_version": 3,
  "name": "SachCheck – Indian News Fact-Checker",
  "version": "2.0.0",
  "description": "Real-time fact-checking + voice verdicts for Indian news on YouTube Live. Powered by Gemini AI.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "tts",
    "sidePanel",
    "tabs"
  ],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://generativelanguage.googleapis.com/*",
    "https://api.groq.com/*",
    "https://html.duckduckgo.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "SachCheck",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
